APP_NAME=Carregamento
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=carregamento
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@carregamento.local"
MAIL_FROM_NAME="${APP_NAME}"

# Guardian (Prix) - SOAP - sem autenticação - pesos em kg
GUARDIAN_WSDL=http://177.221.101.197:9148/ws_guardian/ws_guardian_plus.asmx?wsdl
GUARDIAN_MOCK=true
GUARDIAN_TIMEOUT=10

# Protheus - REST/HTTP (definir URL e credenciais)
PROTHEUS_BASE_URL=
PROTHEUS_USERNAME=
PROTHEUS_PASSWORD=
PROTHEUS_MOCK=true
PROTHEUS_TIMEOUT=15

# Reverb (WebSocket)
# REVERB_HOST/PORT/SCHEME = como o BACKEND alcança o Reverb (hostname interno do
# docker-compose — não editar pra um host externo). VITE_REVERB_* = como o
# CLIENTE (painel Vue) conecta, via nginx na mesma porta da aplicação — ajustar
# pro host:porta real de cada ambiente. Ver DT-013.
REVERB_APP_ID=carregamento
REVERB_APP_KEY=carregamento-key
REVERB_APP_SECRET=carregamento-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=80
VITE_REVERB_SCHEME=http
