<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- A maioria dos valores de teste é forçada via $_SERVER em tests/bootstrap.php
             (necessário porque PHPUnit <env force="true"> só escreve em $_ENV/putenv(),
             e o Env do Laravel dá prioridade a $_SERVER). DB_HOST/DB_PORT ficam só aqui,
             sem force, porque dependem do contexto: dentro do container devem herdar
             postgres:5432 do app/.env real; a partir do host caem neste fallback
             127.0.0.1:5433 (porta mapeada em docker-compose.override.yml). -->
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5433"/>
    </php>
</phpunit>
