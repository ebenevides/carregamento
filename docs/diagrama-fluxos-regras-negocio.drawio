  <diagram id="page-arquitetura" name="Backend - Arquitetura e Integracoes">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title2" value="Camadas do backend e integracoes externas (RN-008: Protheus/Guardian so via adapters)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="b1" value="Painel Web&lt;br&gt;(Vue 3 + Inertia)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;routes/web.php — sessao (auth+verified)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="App Mobile&lt;br&gt;(Flutter — operador/motorista)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;routes/api.php v1 — Sanctum token&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="210" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="Controllers&lt;br&gt;(Web\* e Api\V1\*)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="120" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b4" value="Actions / Services&lt;br&gt;Domain/Carregamento, Fila,&lt;br&gt;Divergencia, Pesagem" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="610" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b5" value="Models / DB&lt;br&gt;(PostgreSQL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="650" y="280" width="150" height="70" as="geometry" />
        </mxCell>

        <mxCell id="b6" value="Adapters&lt;br&gt;Domain/Integrations/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="910" y="120" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b7" value="GuardianAdapterInterface&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;GuardianSoapAdapter (real) /&lt;br&gt;GuardianMockAdapter (GUARDIAN_MOCK=true)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1170" y="40" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="b8" value="ProtheusAdapterInterface&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ProtheusHttpAdapter (real) /&lt;br&gt;ProthousMockAdapter (PROTHEUS_MOCK=true, typo proposital)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1170" y="150" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="b9" value="Prix Guardian&lt;br&gt;(balanca — protocolo SOAP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1470" y="40" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="b10" value="Protheus&lt;br&gt;(pedidos/contratos — HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1470" y="160" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="warn" value="RN-008: Protheus e Guardian nunca sao acessados direto pelo frontend Vue&lt;br&gt;ou pelo app Flutter — sempre atraves de Domain/Integrations/*." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;dashed=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="280" width="290" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="b1" target="b3"><mxGeometry relative="1" as="geometry" /></mxCell>
