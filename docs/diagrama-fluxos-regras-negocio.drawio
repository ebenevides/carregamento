  <diagram id="page-regras-negocio" name="Regras de Negocio (RN-001 a RN-011)">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title3" value="Regras de negocio (docs/regras-negocio.md + roadmap operador/motorista)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="820" height="30" as="geometry" />
        </mxCell>

        <mxCell id="rn1" value="RN-001 — Ordem sem ticket_guardian nao vai para carregamento." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn2" value="RN-002 — Ordem sem tara registrada nao vai para carregamento." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn3" value="RN-003 — Todo produto precisa de produto_pilha_ponto ativo=true; ausencia gera divergencia PILHA_SEM_PRODUTO." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn4" value="RN-004 — Operador enxerga apenas as ordens do seu ponto_carregamento_id." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn5" value="RN-005 — Ordem com divergencia ABERTA nao pode ir para EM_CARREGAMENTO." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn6" value="RN-006 — Toda mudanca de status cria evento em eventos_ordem_carregamento (usuario, origem, status_anterior/novo). Sempre via AlterarStatusOrdemAction — nunca mutar status direto." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="800" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rn7" value="RN-007 — Peso valido se |peso_liquido - quantidade_prevista| &lt;= quantidade_prevista * tolerancia_percentual / 100 (padrao 5%). Fora disso: PESO_FORA_TOLERANCIA." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="800" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rn8" value="RN-008 — Protheus e Guardian sao acessados apenas via Domain/Integrations/* — nunca direto do frontend web ou do app Flutter." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rn9" value="RN-009 — Acao &quot;Rejeitar&quot; do operador sempre gera DIVERGENCIA (com descricao obrigatoria) — nunca CANCELADO direto. Cancelamento definitivo continua restrito a EXPEDICAO/ADMIN." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="800" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rn10" value="RN-010 — rejeitar, concluir e fila-carregamento/{ordem}/liberar exigem ponto_carregamento_id do usuario == ponto_carregamento_id da ordem (403 caso contrario). Reforca RN-004." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="800" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rn11" value="RN-011 — Envio de mensagem no chat (POST mensagens) so funciona com ordem.status-&gt;estaAtivo() == true; senao 422. Historico continua legivel em ordens finalizadas/canceladas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="legend3" value="Cinza = validacao de dado | Azul = autorizacao/visibilidade | Laranja = divergencia/fluxo alternativo | Roxo = arquitetura | Verde = chat" style="text;html=1;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="800" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

