        <mxCell id="title4" value="App Flutter (mobile/) — navegacao operador e motorista (single codebase, go_router)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="900" height="30" as="geometry" />
