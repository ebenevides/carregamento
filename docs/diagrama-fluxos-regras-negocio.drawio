        <mxCell id="m1" value="App start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="LoginScreen&lt;br&gt;email + senha" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="200" height="60" as="geometry" />
