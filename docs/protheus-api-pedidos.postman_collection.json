{
  "info": {
    "_postman_id": "protheus-api-pedidos-v1",
    "name": "Protheus API — Pedidos de Venda",
    "description": "API REST de Pedidos de Venda (SC5/SA1/SC6) e Contratos de Parceria (ADA/ADB/SA1) — Protheus 12.1.2410+\n\nEndpoints:\n  GET    /api/v1/faturamento/pedidos\n  GET    /api/v1/faturamento/pedidos/:filial/:numero\n  POST   /api/v1/faturamento/pedidos\n  PUT    /api/v1/faturamento/pedidos/:filial/:numero\n  GET    /api/v1/parceria/contratos\n\nConfigure a variável {{base_url}} com o endereço do AppServer (ex: http://200.106.188.113:8402).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "URL base do AppServer Protheus (sem barra final)"
    },
    {
      "key": "filial",
      "value": "01",
      "description": "Filial padrão para testes"
    },
    {
      "key": "numero",
      "value": "000001",
      "description": "Número do pedido para testes"
    },
    {
      "key": "token",
      "value": "",
      "description": "Bearer token de autenticação (opcional)"
    },
    {
      "key": "codCliente",
      "value": "000001",
      "description": "Código do cliente para testes de contratos de parceria"
    },
    {
      "key": "numeroContrato",
      "value": "000123",
      "description": "Número do contrato de parceria para testes"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
