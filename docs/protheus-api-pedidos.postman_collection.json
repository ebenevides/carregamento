              "raw": "{\n  \"cliente\": \"000001\",\n  \"loja\": \"01\",\n  \"condPagamento\": \"001\",\n  \"vendedor\": \"000001\",\n  \"transportadora\": \"\",\n  \"mensagemNota\": \"Pedido via API REST\",\n  \"itens\": [\n    {\n      \"produto\": \"PROD001\",\n      \"quantidade\": 10,\n      \"preco\": 150.00,\n      \"tes\": \"501\",\n      \"armazem\": \"01\"\n    },\n    {\n      \"produto\": \"PROD002\",\n      \"quantidade\": 5,\n      \"preco\": 200.00,\n      \"tes\": \"501\",\n      \"armazem\": \"01\"\n    }\n  ]\n}",
