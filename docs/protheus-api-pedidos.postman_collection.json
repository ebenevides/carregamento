              "raw": "{\n  \"condPagamento\": \"002\",\n  \"itens\": [\n    {\n      \"produto\": \"PROD001\",\n      \"quantidade\": 20,\n      \"preco\": 145.00,\n      \"tes\": \"501\",\n      \"armazem\": \"01\"\n    }\n  ]\n}",
